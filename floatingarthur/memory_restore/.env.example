# baseline | realesrgan
RESTORATION_BACKEND=baseline

# 학교 서버에서 Real-ESRGAN을 준비한 뒤 아래 템플릿을 설정한다.
# {input}, {output}, {model}, {outscale}, {tile} 다섯 값을 반드시 포함한다.
# 예: /opt/venv/bin/python /workspace/memory_restore/scripts/realesrgan_worker.py --input {input} --output {output} --model {model} --outscale {outscale} --tile {tile}
REALESRGAN_COMMAND=
REALESRGAN_MODEL=RealESRGAN_x4plus
REALESRGAN_TILE=256
